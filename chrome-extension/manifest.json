{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0.0",
  "description": "__MSG_extDesc__",
  "default_locale": "ko",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://kyangkyongkyungkyang.github.io/*"],
  "content_security_policy": {
